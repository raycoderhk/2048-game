# OpenClaw .gitignore

# ============================================
# 敏感文件 (Secrets)
# ============================================
.env
.env.local
.env.production
.env.development
*.env

# ============================================
# 備份文件
# ============================================
*.backup.*
*.bak
*.old
*.orig
backups/

# ============================================
# 日誌文件
# ============================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================
# 臨時文件
# ============================================
tmp/
temp/
*.tmp
*.swp
*.swo
*~

# ============================================
# 操作系統文件
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ============================================
# Node.js
# ============================================
node_modules/
npm-debug.log
yarn-error.log
coverage/
.nyc_output/

# ============================================
# IDE
# ============================================
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# ============================================
# OpenClaw Specific
# ============================================
openclaw.json.backup*
secrets.json
*.key
*.pem
*.crt

# ============================================
# Media (可選 - 如果你想忽略下載的媒體)
# ============================================
# media/inbound/
# media/outbound/

# ============================================
# Memory (可選 - 如果你想保持私人)
# ============================================
# memory/
# MEMORY.md

# ============================================
# Notes
# ============================================
# 1. 此文件可以安全分享/commit 到 Git
# 2. 確保 .env 被正確忽略
# 3. 定期檢查 git status 確認無敏感文件
