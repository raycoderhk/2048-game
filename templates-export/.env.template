# OpenClaw .env Template

# 複製此文件為 ~/.openclaw/.env 並填充你的實際 values

# ============================================
# AI Models API Keys
# ============================================

# Aliyun (Qwen) - 主要模型
# 獲取：https://bailian.console.aliyun.com/
ALIYUN_API_KEY=sk-your-api-key-here

# DeepSeek - 可選
# 獲取：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-api-key-here

# OpenRouter - 可選
# 獲取：https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-your-api-key-here

# ============================================
# Messaging Platforms
# ============================================

# Discord Bot Token
# Discord Developer Portal → Your App → Bot → Token
DISCORD_BOT_TOKEN=MTQ3NjUwMTI4Nzc0MTk1MjEwMA.your-token-here

# Telegram Bot Token
# @BotFather → New Bot → Token
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ============================================
# Gateway Configuration
# ============================================

# Gateway Auth Token (自定義一個強的 random string)
# 生成：openssl rand -hex 32
GATEWAY_AUTH_TOKEN=your-gateway-secret-token-here

# ============================================
# Web Services (可選)
# ============================================

# Brave Search API
# 獲取：https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=your-brave-search-key-here

# Tavily API (可選)
# 獲取：https://tavily.com/
TAVILY_API_KEY=your-tavily-key-here

# ============================================
# Other Services (可選)
# ============================================

# Supabase (如果使用 Dashboard)
# 獲取：https://app.supabase.com/
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Zeabur (如果部署到 Zeabur)
# 獲取：https://zeabur.com/
ZEABUR_API_KEY=your-zeabur-key-here

# ============================================
# Notes
# ============================================
# 1. 此文件應該加入 .gitignore
# 2. 不要 commit 此文件到 Git
# 3. 只在本機保存，不要分享
# 4. 定期更換 secrets
# 5. 使用強的 random strings
